# ===================================================
# AgentFlow Framework - Environment Configuration
# Copy to .env and fill in your values
# ===================================================

# ---- Database (SQLite for local dev, PostgreSQL for production) ----
# For SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./agentflow.db
SYNC_DATABASE_URL=sqlite:///./agentflow.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://agentflow:agentflow@localhost:5432/agentflow
# SYNC_DATABASE_URL=postgresql://agentflow:agentflow@localhost:5432/agentflow

# ---- PRIMARY LLM - Grok via Groq API (FREE tier available) ----
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Default model (Grok = llama3 on Groq infrastructure)
ACTIVE_LLM_MODEL=groq/llama3-70b-8192
# Other Groq models:
# ACTIVE_LLM_MODEL=groq/llama3-8b-8192
# ACTIVE_LLM_MODEL=groq/mixtral-8x7b-32768
# ACTIVE_LLM_MODEL=groq/gemma2-9b-it

# ---- Other LLM Keys (optional fallbacks) ----
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
COHERE_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=pplx-...
FIREWORKS_API_KEY=fw_...
DEEPSEEK_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---- Memory Configuration ----
ENABLE_MEMORY=true
MEMORY_BACKEND=db
MEMORY_WINDOW_SIZE=20

# ---- App Settings ----
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
CORS_ORIGINS=*
HUMAN_APPROVAL_REQUIRED=false

API_HOST=0.0.0.0
API_PORT=8000
